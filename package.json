{
  "name": "tikz-drawer",
  "version": "1.0.26",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "generate:latex-validation": "tsx scripts/generate-tikz-validation-output.mts",
    "capture:release": "tsx scripts/release-screenshots.mts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "pnpm run lint:eslint && pnpm run lint:format",
    "lint:eslint": "eslint . --max-warnings=0",
    "lint:eslint:fix": "eslint . --fix",
    "lint-fix": "pnpm run lint:eslint:fix && prettier --write \"**/*.{ts,html,css,scss,json,md}\"",
    "format": "prettier --write \"**/*.{ts,html,css,scss,json,md}\"",
    "lint-format": "pnpm run lint-fix",
    "lint:format": "prettier --check \"**/*.{ts,html,css,scss,json,md}\"",
    "sonar:scan": "sonar-scanner"
  },
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "dependencies": {
    "@angular/common": "^21.2.9",
    "@angular/compiler": "^21.2.9",
    "@angular/core": "^21.2.9",
    "@angular/forms": "^21.2.9",
    "@angular/platform-browser": "^21.2.9",
    "@angular/router": "^21.2.9",
    "@angular/service-worker": "^21.2.9",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.9",
    "@eslint/js": "^9.37.0",
    "angular-eslint": "^21.2.0",
    "eslint": "^9.37.0",
    "jsdom": "^28.0.0",
    "playwright": "^1.55.0",
    "prettier": "^3.8.3",
    "sonar-scanner": "^3.1.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
