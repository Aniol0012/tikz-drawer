{
  "name": "tikz-drawer",
  "version": "1.2.63",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "generate:latex-validation": "tsx scripts/generate-tikz-validation-output.mts",
    "validate:i18n": "tsx scripts/validate-i18n.mts",
    "validate:i18n:all": "tsx scripts/validate-i18n.mts --all",
    "capture:release": "tsx scripts/release-screenshots.mts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "pnpm run lint:eslint && pnpm run lint:format",
    "lint:eslint": "eslint . --max-warnings=0",
    "lint:eslint:fix": "eslint . --fix",
    "lint-fix": "pnpm run lint:eslint:fix && prettier --write \"**/*.{ts,html,css,scss,json,md}\"",
    "format": "prettier --write \"**/*.{ts,html,css,scss,json,md}\"",
    "lint-format": "pnpm run lint-fix",
    "lint:format": "prettier --check \"**/*.{ts,html,css,scss,json,md}\"",
    "optimize:png": "tsx scripts/optimize-png.mts",
    "sonar:scan": "sonar-scanner"
  },
  "private": true,
  "packageManager": "pnpm@10.33.1+sha512.05ba3c1d5d1c18f68df06470d74055e62d41fc110a0c660db1b2dfb2785327f04cf0f68345d4609bc52089e7fa0343c31593b2f9594e2c5d5da426230acc9820",
  "dependencies": {
    "@angular/common": "^22.0.4",
    "@angular/compiler": "^22.0.4",
    "@angular/core": "^22.0.4",
    "@angular/forms": "^22.0.4",
    "@angular/platform-browser": "^22.0.4",
    "@angular/router": "^22.0.4",
    "@angular/service-worker": "^22.0.4",
    "@mlc-ai/web-llm": "^0.2.84",
    "@shoelace-style/shoelace": "^2.20.1",
    "firebase": "^12.15.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.4",
    "@eslint/js": "^9.37.0",
    "angular-eslint": "^22.0.0",
    "eslint": "^9.37.0",
    "fallow": "^2.101.0",
    "jsdom": "^28.0.0",
    "playwright": "^1.61.0",
    "prettier": "^3.8.4",
    "sharp": "^0.35.2",
    "sonar-scanner": "^3.1.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
